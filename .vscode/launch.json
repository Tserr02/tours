{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: запустить сайт",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\manage.py",
            "args": [
                "runserver",
                "127.0.0.1:8000"
            ],
            "django": true,
            "justMyCode": true,
            "envFile": "${workspaceFolder}\\.env"
        },
        {
            "name": "Django: тесты",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\manage.py",
            "args": [
                "test"
            ],
            "django": true,
            "justMyCode": true,
            "envFile": "${workspaceFolder}\\.env"
        }
    ]
}
